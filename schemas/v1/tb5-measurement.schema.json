{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/tb5-measurement.schema.json",
  "title": "QW5 Thunderbolt 5 application-path measurement v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifact_role",
    "evidence_class",
    "run_id",
    "created_at",
    "identity",
    "scenario",
    "payload_bytes",
    "mode",
    "warmup",
    "sampling",
    "socket",
    "attempts",
    "summary",
    "errors"
  ],
  "properties": {
    "schema": { "const": "qw5.tb5-measurement/v1" },
    "artifact_role": { "enum": ["measurement", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "run_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qw5_commit", "dirty", "plan_sha256", "harness_sha256", "route_proof_sha256", "inventory_sha256"],
      "properties": {
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "plan_sha256": { "$ref": "#/$defs/sha256" },
        "harness_sha256": { "$ref": "#/$defs/sha256" },
        "route_proof_sha256": { "$ref": "#/$defs/sha256" },
        "inventory_sha256": {
          "type": "object",
          "additionalProperties": false,
          "required": ["A", "B", "C"],
          "properties": {
            "A": { "$ref": "#/$defs/sha256" },
            "B": { "$ref": "#/$defs/sha256" },
            "C": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "flows", "start_skew_limit_ns"],
      "properties": {
        "scenario_id": {
          "enum": [
            "solo-a-b", "solo-b-a", "solo-a-c", "solo-c-a", "solo-b-c", "solo-c-b",
            "duplex-a-b", "duplex-a-c", "duplex-b-c",
            "fanout-a", "fanout-b", "fanout-c",
            "fanin-a", "fanin-b", "fanin-c",
            "cycle-a-b-c", "cycle-a-c-b", "all-directed"
          ]
        },
        "flows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/flow" }
        },
        "start_skew_limit_ns": { "const": 10000000 }
      }
    },
    "payload_bytes": {
      "enum": [64, 256, 1024, 4096, 16384, 65536, 262144, 1048576, 4194304, 16777216, 67108864, 268435456]
    },
    "mode": { "enum": ["stream", "round_trip"] },
    "warmup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planned_repetitions", "completed_repetitions", "minimum_duration_ns", "minimum_messages"],
      "properties": {
        "planned_repetitions": { "type": "integer", "minimum": 0 },
        "completed_repetitions": { "type": "integer", "minimum": 0 },
        "minimum_duration_ns": { "type": "integer", "minimum": 0 },
        "minimum_messages": { "type": "integer", "minimum": 1 }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planned_valid_repetitions", "maximum_attempts", "minimum_duration_ns", "minimum_messages"],
      "properties": {
        "planned_valid_repetitions": { "type": "integer", "minimum": 1 },
        "maximum_attempts": { "type": "integer", "minimum": 1 },
        "minimum_duration_ns": { "type": "integer", "minimum": 0 },
        "minimum_messages": { "type": "integer", "minimum": 1 }
      }
    },
    "socket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "persistent", "tcp_nodelay", "tls", "compression", "send_buffer_bytes", "receive_buffer_bytes"],
      "properties": {
        "transport": { "const": "tcp" },
        "persistent": { "const": true },
        "tcp_nodelay": { "const": true },
        "tls": { "const": false },
        "compression": { "const": false },
        "send_buffer_bytes": { "type": "integer", "minimum": 1 },
        "receive_buffer_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/attempt" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_attempts", "invalid_attempts", "outcome", "flow_summaries"],
      "properties": {
        "valid_attempts": { "type": "integer", "minimum": 0 },
        "invalid_attempts": { "type": "integer", "minimum": 0 },
        "outcome": { "enum": ["complete", "failed", "aborted"] },
        "flow_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow_summary" }
        }
      }
    },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "measurement" } } },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "node": { "enum": ["A", "B", "C"] },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flow_id", "source", "destination", "route_alias"],
      "properties": {
        "flow_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "source": { "$ref": "#/$defs/node" },
        "destination": { "$ref": "#/$defs/node" },
        "route_alias": { "type": "string", "pattern": "^[A-C]-[A-C]$" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "thermal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "start_state", "end_state", "low_power_mode", "power_source"],
      "properties": {
        "node": { "$ref": "#/$defs/node" },
        "start_state": { "type": "string", "minLength": 1 },
        "end_state": { "type": "string", "minLength": 1 },
        "low_power_mode": { "type": "boolean" },
        "power_source": { "type": ["string", "null"] }
      }
    },
    "copy_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "method"],
      "properties": {
        "stage": { "enum": ["producer_to_send", "send_to_transport", "transport_to_receive", "receive_to_consumer", "kernel_dma_hardware"] },
        "status": { "enum": ["available", "unavailable", "error"] },
        "count": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "method": { "type": "string", "minLength": 1 },
        "error": { "$ref": "#/$defs/error" }
      }
    },
    "flow_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id", "messages", "payload_bytes", "header_bytes", "ack_bytes",
        "receiver_elapsed_ns", "checksum_algorithm", "checksum_count",
        "checksum_elapsed_ns", "sequence_first", "sequence_last", "copies"
      ],
      "properties": {
        "flow_id": { "type": "string", "minLength": 1 },
        "messages": { "type": "integer", "minimum": 0 },
        "payload_bytes": { "type": "integer", "minimum": 0 },
        "header_bytes": { "type": "integer", "minimum": 0 },
        "ack_bytes": { "type": "integer", "minimum": 0 },
        "receiver_elapsed_ns": { "type": "integer", "minimum": 1 },
        "round_trip_ns": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
        "checksum_algorithm": { "const": "sha256" },
        "checksum_count": { "type": "integer", "minimum": 0 },
        "checksum_elapsed_ns": { "type": "integer", "minimum": 0 },
        "sequence_first": { "type": "integer", "minimum": 0 },
        "sequence_last": { "type": "integer", "minimum": 0 },
        "copies": { "type": "array", "items": { "$ref": "#/$defs/copy_stage" } }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "valid", "started_at", "ended_at", "start_skew_ns", "thermal", "flows", "errors"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "valid": { "type": "boolean" },
        "started_at": { "$ref": "#/$defs/timestamp" },
        "ended_at": { "$ref": "#/$defs/timestamp" },
        "start_skew_ns": { "type": "integer", "minimum": 0 },
        "thermal": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/thermal" } },
        "flows": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/flow_sample" } },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
      }
    },
    "flow_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flow_id", "sample_count", "median_bytes_per_second", "p95_bytes_per_second", "minimum_bytes_per_second", "maximum_bytes_per_second"],
      "properties": {
        "flow_id": { "type": "string", "minLength": 1 },
        "sample_count": { "type": "integer", "minimum": 0 },
        "median_bytes_per_second": { "type": "number", "minimum": 0 },
        "p95_bytes_per_second": { "type": "number", "minimum": 0 },
        "minimum_bytes_per_second": { "type": "number", "minimum": 0 },
        "maximum_bytes_per_second": { "type": "number", "minimum": 0 }
      }
    }
  }
}
