{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/placement-evidence-graph.schema.json",
  "title": "QW5 placement evidence graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "created_at", "producer",
    "analysis_identity", "nodes", "gate_resolutions", "allocation_resolutions",
    "required_memory_classes"
  ],
  "properties": {
    "schema": { "const": "qw5.placement-evidence-graph/v1" },
    "artifact_role": { "enum": ["placement_evidence_graph", "schema_fixture"] },
    "evidence_class": { "enum": ["ESTIMATED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "analysis_identity": {
      "type": "object", "additionalProperties": false,
      "required": ["repository_id", "immutable_revision", "component_scope", "phase", "context_tokens", "candidate_id"],
      "properties": {
        "repository_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "immutable_revision": { "$ref": "#/$defs/git_commit" },
        "component_scope": { "enum": ["complete_artifact", "text_execution_subset", "schema_fixture"] },
        "phase": { "enum": ["prefill", "decode"] },
        "context_tokens": { "enum": [4096, 32768, 262144] },
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" }
      }
    },
    "nodes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/node" }
    },
    "gate_resolutions": {
      "type": "array", "minItems": 10, "maxItems": 10, "uniqueItems": true,
      "items": { "$ref": "#/$defs/gate_resolution" }
    },
    "allocation_resolutions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/allocation_resolution" }
    },
    "required_memory_classes": {
      "const": [
        "allocator", "artifact_staging", "control", "fragmentation", "kv_state",
        "quantization_metadata", "recurrent_state", "router_state", "scratch",
        "transport", "weights"
      ]
    }
  },
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "node_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "gate_id": {
      "enum": [
        "artifact_complete", "tensor_reconciled", "layout_complete",
        "memory_baseline_accepted", "memory_nonnegative", "quality_available",
        "scratch_bounded", "state_bounded", "transport_profile_available",
        "text_subset_proven"
      ]
    },
    "memory_class": {
      "enum": [
        "allocator", "artifact_staging", "control", "fragmentation", "kv_state",
        "quantization_metadata", "recurrent_state", "router_state", "scratch",
        "transport", "weights"
      ]
    },
    "producer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["node_id", "role", "schema", "evidence_class", "acceptance_status", "relative_path", "sha256"],
      "properties": {
        "node_id": { "$ref": "#/$defs/node_id" },
        "role": {
          "enum": [
            "model_manifest", "tensor_inventory", "hardware_inventory_a",
            "hardware_inventory_b", "hardware_inventory_c", "memory_baseline_a",
            "memory_baseline_b", "memory_baseline_c", "link_summary",
            "quantization_layout", "formula_set", "text_subset_dependency",
            "gate_rule_set", "placement_candidate_set", "solver_objective",
            "reserve_headroom_policy", "quality_evidence", "allocation_evidence",
            "gate_evidence"
          ]
        },
        "schema": { "type": "string", "pattern": "^qw5\\.[a-z0-9.-]+/v[0-9]+$" },
        "evidence_class": { "enum": ["MEASURED", "SIMULATED", "ESTIMATED", "TARGET"] },
        "acceptance_status": { "enum": ["accepted", "owner_approval_required", "rejected"] },
        "relative_path": { "$ref": "#/$defs/relative_path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "gate_resolution": {
      "type": "object", "additionalProperties": false,
      "required": ["gate_id", "disposition", "rule_id", "evidence_node_ids"],
      "properties": {
        "gate_id": { "$ref": "#/$defs/gate_id" },
        "disposition": { "enum": ["passed", "failed", "unresolved", "not_applicable"] },
        "rule_id": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "evidence_node_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/node_id" } }
      }
    },
    "allocation_resolution": {
      "type": "object", "additionalProperties": false,
      "required": ["allocation_id", "memory_class", "formula_id", "evidence_node_ids", "zero_bytes_proof_node_id"],
      "properties": {
        "allocation_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "memory_class": { "$ref": "#/$defs/memory_class" },
        "formula_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "evidence_node_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/node_id" } },
        "zero_bytes_proof_node_id": { "anyOf": [{ "$ref": "#/$defs/node_id" }, { "type": "null" }] }
      }
    }
  }
}
