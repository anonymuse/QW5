{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/hardware-inventory.schema.json",
  "title": "QW5 hardware inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "node_alias", "collection",
    "producer", "sources", "facts", "links", "collection_errors", "redactions"
  ],
  "properties": {
    "schema": { "const": "qw5.hardware-inventory/v1" },
    "artifact_role": { "enum": ["inventory", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "node_alias": { "$ref": "#/$defs/node" },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "ended_at"],
      "properties": {
        "started_at": { "$ref": "#/$defs/timestamp" },
        "ended_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "producer": { "$ref": "#/$defs/producer" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source" }
    },
    "facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clock.monotonic_name", "clock.monotonic_resolution_ns", "clock.sync_method",
        "clock.sync_uncertainty_ns", "cpu.efficiency_core_count", "cpu.logical_core_count",
        "cpu.performance_core_count", "cpu.physical_core_count", "gpu.core_count",
        "gpu.device_count", "gpu.device_name", "gpu.has_unified_memory",
        "gpu.recommended_working_set_bytes", "hardware.model_identifier",
        "memory.available_bytes", "memory.page_bytes", "memory.physical_bytes",
        "memory.pressure_level", "os.build", "os.kernel_release", "os.product_version",
        "power.low_power_mode", "power.source", "soc.name",
        "storage.available_important_bytes", "storage.internal", "storage.total_bytes",
        "thermal.state", "thunderbolt.controller_count", "tool.zig_version"
      ],
      "properties": {
        "clock.monotonic_name": { "$ref": "#/$defs/string_none_fact" },
        "clock.monotonic_resolution_ns": { "$ref": "#/$defs/integer_ns_fact" },
        "clock.sync_method": { "$ref": "#/$defs/string_none_fact" },
        "clock.sync_uncertainty_ns": { "$ref": "#/$defs/integer_ns_fact" },
        "cpu.efficiency_core_count": { "$ref": "#/$defs/integer_count_fact" },
        "cpu.logical_core_count": { "$ref": "#/$defs/integer_count_fact" },
        "cpu.performance_core_count": { "$ref": "#/$defs/integer_count_fact" },
        "cpu.physical_core_count": { "$ref": "#/$defs/integer_count_fact" },
        "gpu.core_count": { "$ref": "#/$defs/integer_count_fact" },
        "gpu.device_count": { "$ref": "#/$defs/integer_count_fact" },
        "gpu.device_name": { "$ref": "#/$defs/string_none_fact" },
        "gpu.has_unified_memory": { "$ref": "#/$defs/boolean_none_fact" },
        "gpu.recommended_working_set_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "hardware.model_identifier": { "$ref": "#/$defs/string_none_fact" },
        "memory.available_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "memory.page_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "memory.physical_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "memory.pressure_level": { "$ref": "#/$defs/string_none_fact" },
        "os.build": { "$ref": "#/$defs/string_none_fact" },
        "os.kernel_release": { "$ref": "#/$defs/string_none_fact" },
        "os.product_version": { "$ref": "#/$defs/string_none_fact" },
        "power.low_power_mode": { "$ref": "#/$defs/boolean_none_fact" },
        "power.source": { "$ref": "#/$defs/string_none_fact" },
        "soc.name": { "$ref": "#/$defs/string_none_fact" },
        "storage.available_important_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "storage.internal": { "$ref": "#/$defs/boolean_none_fact" },
        "storage.total_bytes": { "$ref": "#/$defs/integer_bytes_fact" },
        "thermal.state": { "$ref": "#/$defs/string_none_fact" },
        "thunderbolt.controller_count": { "$ref": "#/$defs/integer_count_fact" },
        "tool.zig_version": { "$ref": "#/$defs/string_none_fact" }
      }
    },
    "links": {
      "type": "array",
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/link" }
    },
    "collection_errors": { "type": "array", "items": { "$ref": "#/$defs/error" } },
    "redactions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "credentials", "hardware_uuid", "home_path", "hostname", "ip_address",
          "mac_address", "mount_path", "serial_number", "token", "username"
        ]
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "inventory" } }, "required": ["artifact_role"] },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    },
    {
      "oneOf": [
        {
          "properties": {
            "links": { "minItems": 2, "maxItems": 2 }
          }
        },
        {
          "properties": {
            "links": { "maxItems": 0 },
            "collection_errors": { "minItems": 1 }
          }
        }
      ]
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "node": { "enum": ["A", "B", "C"] },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "kind", "name", "provider", "version", "description"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "kind": { "enum": ["api", "command"] },
        "name": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "version": { "type": ["string", "null"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "fact_status": {
      "type": "object",
      "required": ["status", "source_ref", "observed_at"],
      "properties": {
        "status": { "enum": ["available", "unavailable", "error"] },
        "value": { "type": ["boolean", "integer", "string"] },
        "unit": { "enum": ["bytes", "count", "none", "ns"] },
        "source_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        {
          "properties": { "status": { "const": "available" } },
          "required": ["value", "unit"],
          "not": { "required": ["error"] }
        },
        {
          "properties": { "status": { "const": "unavailable" } },
          "not": { "anyOf": [{ "required": ["value"] }, { "required": ["unit"] }, { "required": ["error"] }] }
        },
        {
          "properties": { "status": { "const": "error" } },
          "required": ["error"],
          "not": { "anyOf": [{ "required": ["value"] }, { "required": ["unit"] }] }
        }
      ]
    },
    "string_none_fact": {
      "allOf": [
        { "$ref": "#/$defs/fact_status" },
        {
          "if": { "properties": { "status": { "const": "available" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "string" }, "unit": { "const": "none" } } }
        }
      ],
      "unevaluatedProperties": false
    },
    "boolean_none_fact": {
      "allOf": [
        { "$ref": "#/$defs/fact_status" },
        {
          "if": { "properties": { "status": { "const": "available" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "boolean" }, "unit": { "const": "none" } } }
        }
      ],
      "unevaluatedProperties": false
    },
    "integer_bytes_fact": {
      "allOf": [
        { "$ref": "#/$defs/fact_status" },
        {
          "if": { "properties": { "status": { "const": "available" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "integer", "minimum": 0 }, "unit": { "const": "bytes" } } }
        }
      ],
      "unevaluatedProperties": false
    },
    "integer_count_fact": {
      "allOf": [
        { "$ref": "#/$defs/fact_status" },
        {
          "if": { "properties": { "status": { "const": "available" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "integer", "minimum": 0 }, "unit": { "const": "count" } } }
        }
      ],
      "unevaluatedProperties": false
    },
    "integer_ns_fact": {
      "allOf": [
        { "$ref": "#/$defs/fact_status" },
        {
          "if": { "properties": { "status": { "const": "available" } }, "required": ["status"] },
          "then": { "properties": { "value": { "type": "integer", "minimum": 0 }, "unit": { "const": "ns" } } }
        }
      ],
      "unevaluatedProperties": false
    },
    "optional_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source_ref"],
      "properties": {
        "status": { "enum": ["available", "unavailable", "error"] },
        "value": { "type": ["integer", "string"] },
        "unit": { "enum": ["bits_per_second", "count", "none"] },
        "source_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        { "properties": { "status": { "const": "available" } }, "required": ["value", "unit"], "not": { "required": ["error"] } },
        { "properties": { "status": { "const": "unavailable" } }, "not": { "anyOf": [{ "required": ["value"] }, { "required": ["unit"] }, { "required": ["error"] }] } },
        { "properties": { "status": { "const": "error" } }, "required": ["error"], "not": { "anyOf": [{ "required": ["value"] }, { "required": ["unit"] }] } }
      ]
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peer_alias", "route_alias", "status", "active", "direct",
        "controller_alias", "port_alias", "negotiated_rate", "negotiated_width",
        "negotiated_generation", "negotiated_lanes", "source_ref", "observed_at"
      ],
      "properties": {
        "peer_alias": { "$ref": "#/$defs/node" },
        "route_alias": { "type": "string", "pattern": "^[A-C]-[A-C]$" },
        "status": { "enum": ["available", "unavailable", "error"] },
        "active": { "type": ["boolean", "null"] },
        "direct": { "type": ["boolean", "null"] },
        "controller_alias": { "type": ["string", "null"], "pattern": "^tb-controller-[0-9]+$" },
        "port_alias": { "type": ["string", "null"], "pattern": "^tb-port-[0-9]+$" },
        "negotiated_rate": { "$ref": "#/$defs/optional_observation" },
        "negotiated_width": { "$ref": "#/$defs/optional_observation" },
        "negotiated_generation": { "$ref": "#/$defs/optional_observation" },
        "negotiated_lanes": { "$ref": "#/$defs/optional_observation" },
        "source_ref": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        {
          "properties": {
            "status": { "const": "available" },
            "active": { "type": "boolean" },
            "direct": { "type": "boolean" },
            "controller_alias": { "type": "string" },
            "port_alias": { "type": "string" }
          },
          "not": { "required": ["error"] }
        },
        {
          "properties": {
            "status": { "const": "unavailable" },
            "active": { "const": null },
            "direct": { "const": null },
            "controller_alias": { "const": null },
            "port_alias": { "const": null }
          },
          "not": { "required": ["error"] }
        },
        {
          "properties": {
            "status": { "const": "error" },
            "active": { "const": null },
            "direct": { "const": null },
            "controller_alias": { "const": null },
            "port_alias": { "const": null }
          },
          "required": ["error"]
        }
      ]
    }
  }
}
