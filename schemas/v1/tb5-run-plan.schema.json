{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/tb5-run-plan.schema.json",
  "title": "QW5 Thunderbolt 5 run plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "plan_id", "approval_status",
    "created_at", "producer", "identity", "seed", "order_algorithm", "matrix",
    "stream_policy", "round_trip_policy", "synchronization", "framing",
    "socket_request", "local_controls", "thermal_policy"
  ],
  "properties": {
    "schema": { "const": "qw5.tb5-run-plan/v1" },
    "artifact_role": { "enum": ["run_plan", "schema_fixture"] },
    "evidence_class": { "const": "TARGET" },
    "plan_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "approval_status": { "enum": ["owner_approval_required", "approved"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qw5_commit", "dirty", "harness_sha256", "route_proof_sha256", "inventory_sha256"],
      "properties": {
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "harness_sha256": { "$ref": "#/$defs/sha256" },
        "route_proof_sha256": { "$ref": "#/$defs/sha256" },
        "inventory_sha256": { "$ref": "#/$defs/node_digests" }
      }
    },
    "seed": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
    "order_algorithm": { "const": "sha256-keyed-sort-v1" },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_order", "scenarios", "stream_payload_bytes",
        "round_trip_scenarios", "round_trip_payload_bytes", "planned_cell_count"
      ],
      "properties": {
        "scenario_order": {
          "const": [
            "solo-a-b", "solo-b-a", "solo-a-c", "solo-c-a", "solo-b-c", "solo-c-b",
            "duplex-a-b", "duplex-a-c", "duplex-b-c", "fanout-a", "fanout-b",
            "fanout-c", "fanin-a", "fanin-b", "fanin-c", "cycle-a-b-c",
            "cycle-a-c-b", "all-directed"
          ]
        },
        "scenarios": {
          "type": "array",
          "minItems": 18,
          "maxItems": 18,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/scenario" }
        },
        "stream_payload_bytes": {
          "const": [64, 256, 1024, 4096, 16384, 65536, 262144, 1048576, 4194304, 16777216, 67108864, 268435456]
        },
        "round_trip_scenarios": {
          "const": ["solo-a-b", "solo-b-a", "solo-a-c", "solo-c-a", "solo-b-c", "solo-c-b"]
        },
        "round_trip_payload_bytes": { "const": [64, 1024, 16384, 262144, 4194304] },
        "planned_cell_count": { "const": 246 }
      }
    },
    "stream_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warmup_repetitions", "warmup_minimum_duration_ns", "valid_repetitions", "maximum_attempts", "sample_minimum_duration_ns", "minimum_messages_per_flow"],
      "properties": {
        "warmup_repetitions": { "const": 3 },
        "warmup_minimum_duration_ns": { "const": 2000000000 },
        "valid_repetitions": { "const": 10 },
        "maximum_attempts": { "const": 12 },
        "sample_minimum_duration_ns": { "const": 3000000000 },
        "minimum_messages_per_flow": { "const": 1 }
      }
    },
    "round_trip_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["small_payload_max_bytes", "small_warmup_exchanges", "small_recorded_exchanges", "large_payload_bytes", "large_warmup_exchanges", "large_recorded_exchanges"],
      "properties": {
        "small_payload_max_bytes": { "const": 262144 },
        "small_warmup_exchanges": { "const": 100 },
        "small_recorded_exchanges": { "const": 1000 },
        "large_payload_bytes": { "const": 4194304 },
        "large_warmup_exchanges": { "const": 20 },
        "large_recorded_exchanges": { "const": 100 }
      }
    },
    "synchronization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_skew_limit_ns", "maximum_uncertainty_ns", "accepted_methods", "insufficient_evidence_outcome"],
      "properties": {
        "start_skew_limit_ns": { "const": 10000000 },
        "maximum_uncertainty_ns": { "const": 1000000 },
        "accepted_methods": {
          "const": ["coordinator_receipt_surrogate"]
        },
        "insufficient_evidence_outcome": { "const": "UNDETERMINED" }
      }
    },
    "framing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "handshake_bytes", "data_header_bytes", "digest_trailer_bytes", "ack_bytes", "checksum"],
      "properties": {
        "protocol": { "const": "qw5-tb5-wire/v1" },
        "handshake_bytes": { "const": 96 },
        "data_header_bytes": { "const": 64 },
        "digest_trailer_bytes": { "const": 32 },
        "ack_bytes": { "const": 64 },
        "checksum": { "const": "sha256" }
      }
    },
    "socket_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "persistent", "tcp_nodelay", "tls", "compression", "send_buffer_bytes", "receive_buffer_bytes", "address_family"],
      "properties": {
        "transport": { "const": "tcp" },
        "persistent": { "const": true },
        "tcp_nodelay": { "const": true },
        "tls": { "const": false },
        "compression": { "const": false },
        "send_buffer_bytes": { "type": "integer", "minimum": 1 },
        "receive_buffer_bytes": { "type": "integer", "minimum": 1 },
        "address_family": { "enum": ["ipv4", "ipv6"] }
      }
    },
    "local_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "payload_bytes", "warmup_repetitions", "recorded_repetitions", "controls", "subtraction_policy"],
      "properties": {
        "nodes": { "const": ["A", "B", "C"] },
        "payload_bytes": {
          "const": [64, 256, 1024, 4096, 16384, 65536, 262144, 1048576, 4194304, 16777216, 67108864, 268435456]
        },
        "warmup_repetitions": { "const": 3 },
        "recorded_repetitions": { "const": 10 },
        "controls": { "const": ["buffer_copy", "framing", "sha256"] },
        "subtraction_policy": { "const": "report_separately_never_subtract" }
      }
    },
    "thermal_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_state", "precondition_duration_ns", "recovery_duration_ns", "maximum_pause_ns"],
      "properties": {
        "required_state": { "const": "nominal" },
        "precondition_duration_ns": { "const": 300000000000 },
        "recovery_duration_ns": { "const": 300000000000 },
        "maximum_pause_ns": { "const": 900000000000 }
      }
    }
  },
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "node": { "enum": ["A", "B", "C"] },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" }
      }
    },
    "node_digests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["A", "B", "C"],
      "properties": {
        "A": { "$ref": "#/$defs/sha256" },
        "B": { "$ref": "#/$defs/sha256" },
        "C": { "$ref": "#/$defs/sha256" }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flow_id", "source", "destination", "route_alias"],
      "properties": {
        "flow_id": { "type": "string", "pattern": "^[a-c]-[a-c]$" },
        "source": { "$ref": "#/$defs/node" },
        "destination": { "$ref": "#/$defs/node" },
        "route_alias": { "type": "string", "pattern": "^[A-C]-[A-C]$" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "flows"],
      "properties": {
        "scenario_id": {
          "enum": [
            "solo-a-b", "solo-b-a", "solo-a-c", "solo-c-a", "solo-b-c", "solo-c-b",
            "duplex-a-b", "duplex-a-c", "duplex-b-c", "fanout-a", "fanout-b",
            "fanout-c", "fanin-a", "fanin-b", "fanin-c", "cycle-a-b-c",
            "cycle-a-c-b", "all-directed"
          ]
        },
        "flows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/flow" }
        }
      }
    }
  }
}
