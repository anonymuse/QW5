{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/model-acquisition-plan.schema.json",
  "title": "QW5 immutable model acquisition plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "created_at", "producer",
    "approval_status", "repository", "model_role", "revision_listing_sha256",
    "required_components", "expected_files", "included_patterns", "excluded_patterns"
  ],
  "properties": {
    "schema": { "const": "qw5.model-acquisition-plan/v1" },
    "artifact_role": { "enum": ["model_acquisition_plan", "schema_fixture"] },
    "evidence_class": { "const": "TARGET" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "approval_status": { "enum": ["owner_approval_required", "approved"] },
    "repository": {
      "type": "object", "additionalProperties": false,
      "required": ["provider", "repository_id", "immutable_revision"],
      "properties": {
        "provider": { "enum": ["huggingface", "fixture"] },
        "repository_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "immutable_revision": { "$ref": "#/$defs/git_commit" }
      }
    },
    "model_role": { "enum": ["first_working_target", "flagship_target", "schema_fixture"] },
    "revision_listing_sha256": { "$ref": "#/$defs/sha256" },
    "required_components": {
      "type": "array", "minItems": 4, "uniqueItems": true,
      "items": { "$ref": "#/$defs/component" }
    },
    "expected_files": {
      "type": "array", "minItems": 4, "uniqueItems": true,
      "items": { "$ref": "#/$defs/expected_file" }
    },
    "included_patterns": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "excluded_patterns": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "component": { "enum": ["configuration", "language", "license", "tokenizer", "vision"] },
    "role": {
      "enum": [
        "configuration", "generation_configuration", "license", "notice",
        "prompt_template", "special_tokens", "tokenizer", "tokenizer_configuration",
        "weight_index", "weight_shard", "other"
      ]
    },
    "producer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "expected_file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "role", "components"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "role": { "$ref": "#/$defs/role" },
        "components": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "$ref": "#/$defs/component" }
        }
      }
    }
  }
}
