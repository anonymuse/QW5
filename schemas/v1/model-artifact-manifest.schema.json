{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/model-artifact-manifest.schema.json",
  "title": "QW5 model artifact manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "created_at", "producer",
    "repository", "selection", "files", "included_patterns", "excluded_patterns",
    "unexpected_files", "completeness"
  ],
  "properties": {
    "schema": { "const": "qw5.model-artifact-manifest/v1" },
    "artifact_role": { "enum": ["model_artifact_manifest", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "repository_id", "immutable_revision", "requested_reference"],
      "properties": {
        "provider": { "enum": ["huggingface", "fixture"] },
        "repository_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "immutable_revision": { "$ref": "#/$defs/git_commit" },
        "requested_reference": { "type": ["string", "null"] }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_role", "components", "revision_listing_sha256", "expected_paths"],
      "properties": {
        "model_role": { "enum": ["first_working_target", "flagship_target", "schema_fixture"] },
        "components": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["configuration", "language", "license", "tokenizer", "vision"] }
        },
        "revision_listing_sha256": { "$ref": "#/$defs/sha256" },
        "expected_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/relative_path" }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/file" }
    },
    "included_patterns": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "excluded_patterns": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "unexpected_files": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/relative_path" } },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "verified_file_count", "verified_total_bytes", "missing_paths",
        "unexpected_paths", "errors"
      ],
      "properties": {
        "status": { "enum": ["complete", "incomplete", "error"] },
        "verified_file_count": { "type": "integer", "minimum": 0 },
        "verified_total_bytes": { "type": "integer", "minimum": 0 },
        "missing_paths": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/relative_path" } },
        "unexpected_paths": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/relative_path" } },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
      },
      "if": { "properties": { "status": { "const": "complete" } }, "required": ["status"] },
      "then": {
        "properties": {
          "missing_paths": { "maxItems": 0 },
          "unexpected_paths": { "maxItems": 0 },
          "errors": { "maxItems": 0 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "model_artifact_manifest" } }, "required": ["artifact_role"] },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    },
    {
      "if": {
        "properties": {
          "completeness": {
            "properties": { "status": { "const": "complete" } },
            "required": ["status"]
          }
        },
        "required": ["completeness"]
      },
      "then": {
        "properties": {
          "unexpected_files": { "maxItems": 0 },
          "files": {
            "items": {
              "properties": { "status": { "const": "verified" } },
              "required": ["status"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verification_pass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass_index", "size_bytes", "sha256", "completed_at"],
      "properties": {
        "pass_index": { "enum": [1, 2] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "completed_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "status", "media_type", "upstream_object_id", "verification_passes"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "role": {
          "enum": [
            "configuration", "generation_configuration", "license", "notice",
            "prompt_template", "special_tokens", "tokenizer", "tokenizer_configuration",
            "weight_index", "weight_shard", "other"
          ]
        },
        "status": { "enum": ["verified", "missing", "error"] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "media_type": { "type": "string", "minLength": 1 },
        "upstream_object_id": { "type": ["string", "null"] },
        "verification_passes": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/verification_pass" } },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        {
          "properties": {
            "status": { "const": "verified" },
            "verification_passes": { "minItems": 2, "maxItems": 2 }
          },
          "required": ["size_bytes", "sha256"],
          "not": { "required": ["error"] }
        },
        {
          "properties": { "status": { "const": "missing" }, "verification_passes": { "maxItems": 0 } },
          "not": { "anyOf": [{ "required": ["size_bytes"] }, { "required": ["sha256"] }, { "required": ["error"] }] }
        },
        {
          "properties": { "status": { "const": "error" }, "verification_passes": { "maxItems": 1 } },
          "required": ["error"],
          "not": { "anyOf": [{ "required": ["size_bytes"] }, { "required": ["sha256"] }] }
        }
      ]
    }
  }
}
