{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/model-artifact-manifest.schema.json",
  "title": "QW5 model artifact manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifact_role",
    "evidence_class",
    "created_at",
    "producer",
    "repository",
    "selection",
    "files",
    "included_patterns",
    "excluded_patterns",
    "unexpected_files",
    "completeness"
  ],
  "properties": {
    "schema": { "const": "qw5.model-artifact-manifest/v1" },
    "artifact_role": { "enum": ["model_artifact_manifest", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "repository_id", "immutable_revision"],
      "properties": {
        "provider": { "enum": ["huggingface", "fixture"] },
        "repository_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "immutable_revision": { "$ref": "#/$defs/git_commit" },
        "requested_reference": { "type": ["string", "null"] }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_role", "components"],
      "properties": {
        "model_role": { "enum": ["first_working_target", "flagship_target", "schema_fixture"] },
        "components": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["configuration", "language", "license", "tokenizer", "vision"] }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/file" }
    },
    "included_patterns": { "type": "array", "items": { "type": "string" } },
    "excluded_patterns": { "type": "array", "items": { "type": "string" } },
    "unexpected_files": { "type": "array", "items": { "$ref": "#/$defs/relative_path" } },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "verified_file_count", "verified_total_bytes", "second_hash_pass"],
      "properties": {
        "status": { "enum": ["complete", "incomplete", "error"] },
        "verified_file_count": { "type": "integer", "minimum": 0 },
        "verified_total_bytes": { "type": "integer", "minimum": 0 },
        "second_hash_pass": { "type": "boolean" },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "model_artifact_manifest" } } },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" },
        "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "status", "media_type", "upstream_object_id"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "role": {
          "enum": [
            "configuration", "generation_configuration", "license", "notice",
            "prompt_template", "special_tokens", "tokenizer", "tokenizer_configuration",
            "weight_index", "weight_shard", "other"
          ]
        },
        "status": { "enum": ["verified", "missing", "error"] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "media_type": { "type": "string", "minLength": 1 },
        "upstream_object_id": { "type": ["string", "null"] },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        {
          "properties": { "status": { "const": "verified" } },
          "required": ["size_bytes", "sha256"],
          "not": { "required": ["error"] }
        },
        {
          "properties": { "status": { "const": "missing" } },
          "not": { "anyOf": [{ "required": ["size_bytes"] }, { "required": ["sha256"] }, { "required": ["error"] }] }
        },
        {
          "properties": { "status": { "const": "error" } },
          "required": ["error"],
          "not": { "anyOf": [{ "required": ["size_bytes"] }, { "required": ["sha256"] }] }
        }
      ]
    }
  }
}
