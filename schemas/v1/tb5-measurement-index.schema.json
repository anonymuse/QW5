{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/tb5-measurement-index.schema.json",
  "title": "QW5 Thunderbolt 5 measurement digest index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "artifact_role", "evidence_class", "created_at", "producer", "plan_sha256", "plan_seed", "canonical_profile", "entries"],
  "properties": {
    "schema": { "const": "qw5.tb5-measurement-index/v1" },
    "artifact_role": { "enum": ["measurement_index", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "plan_seed": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
    "canonical_profile": { "const": "qw5-canonical-json-v1" },
    "entries": { "type": "array", "minItems": 1, "maxItems": 246, "uniqueItems": true, "items": { "$ref": "#/$defs/entry" } }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "measurement_index" } }, "required": ["artifact_role"] },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "producer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" }, "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" }, "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entry": {
      "type": "object", "additionalProperties": false,
      "required": ["cell_id", "relative_path", "sha256"],
      "properties": {
        "cell_id": { "type": "string", "pattern": "^(stream|round-trip):[a-z0-9-]+:[0-9]+$" },
        "relative_path": { "$ref": "#/$defs/relative_path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
