{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/memory-baseline.schema.json",
  "title": "QW5 clean-node memory baseline v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "artifact_role", "evidence_class", "created_at", "node_alias",
    "producer", "inventory_sha256", "policy", "stabilization",
    "metal_working_set_guidance", "samples", "summary", "errors"
  ],
  "properties": {
    "schema": { "const": "qw5.memory-baseline/v1" },
    "artifact_role": { "enum": ["memory_baseline", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "node_alias": { "$ref": "#/$defs/node" },
    "producer": { "$ref": "#/$defs/producer" },
    "inventory_sha256": { "$ref": "#/$defs/sha256" },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_status", "stabilization_duration_ns", "sample_interval_ns",
        "planned_valid_samples", "maximum_attempts", "baseline_statistic",
        "required_thermal_state", "low_power_mode_required", "clean_window_definition"
      ],
      "properties": {
        "approval_status": { "enum": ["owner_approval_required", "approved"] },
        "stabilization_duration_ns": { "const": 600000000000 },
        "sample_interval_ns": { "const": 60000000000 },
        "planned_valid_samples": { "const": 30 },
        "maximum_attempts": { "const": 36 },
        "baseline_statistic": { "const": "nearest-rank-p05-available-bytes" },
        "required_thermal_state": { "const": "nominal" },
        "low_power_mode_required": { "const": false },
        "clean_window_definition": { "type": "string", "minLength": 1 }
      }
    },
    "stabilization": { "$ref": "#/$defs/stabilization" },
    "metal_working_set_guidance": { "$ref": "#/$defs/metal_guidance" },
    "samples": { "type": "array", "minItems": 1, "maxItems": 36, "items": { "$ref": "#/$defs/sample" } },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "attempted_samples", "accepted_samples", "rejected_samples",
        "physical_bytes", "p05_available_bytes", "minimum_available_bytes",
        "maximum_available_bytes", "observed_os_reserve_bytes"
      ],
      "properties": {
        "status": { "enum": ["COMPLETE", "ABORTED", "UNDETERMINED"] },
        "attempted_samples": { "type": "integer", "minimum": 1, "maximum": 36 },
        "accepted_samples": { "type": "integer", "minimum": 0, "maximum": 30 },
        "rejected_samples": { "type": "integer", "minimum": 0, "maximum": 36 },
        "physical_bytes": { "type": "integer", "minimum": 1 },
        "p05_available_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "minimum_available_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "maximum_available_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "observed_os_reserve_bytes": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "memory_baseline" } }, "required": ["artifact_role"] },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "node": { "enum": ["A", "B", "C"] },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" },
        "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" }
      }
    },
    "stabilization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "ended_at", "start_monotonic_ns", "end_monotonic_ns", "observed_duration_ns"],
      "properties": {
        "started_at": { "$ref": "#/$defs/timestamp" },
        "ended_at": { "$ref": "#/$defs/timestamp" },
        "start_monotonic_ns": { "type": "integer", "minimum": 0 },
        "end_monotonic_ns": { "type": "integer", "minimum": 0 },
        "observed_duration_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "metal_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source_fact_id", "interpretation"],
      "properties": {
        "status": { "enum": ["available", "unavailable", "error"] },
        "source_fact_id": { "const": "gpu.recommended_working_set_bytes" },
        "value_bytes": { "type": "integer", "minimum": 0 },
        "interpretation": { "const": "guidance_not_available_memory" },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        { "properties": { "status": { "const": "available" } }, "required": ["value_bytes"], "not": { "required": ["error"] } },
        { "properties": { "status": { "const": "unavailable" } }, "not": { "anyOf": [{ "required": ["value_bytes"] }, { "required": ["error"] }] } },
        { "properties": { "status": { "const": "error" } }, "required": ["error"], "not": { "required": ["value_bytes"] } }
      ]
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_index", "valid", "invalid_reasons", "observed_at",
        "monotonic_ns", "physical_bytes", "available_bytes", "memory_pressure",
        "thermal_state", "low_power_mode", "power_source", "clean_window_verified",
        "errors"
      ],
      "properties": {
        "attempt_index": { "type": "integer", "minimum": 1, "maximum": 36 },
        "valid": { "type": "boolean" },
        "invalid_reasons": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" } },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "monotonic_ns": { "type": "integer", "minimum": 0 },
        "physical_bytes": { "type": "integer", "minimum": 1 },
        "available_bytes": { "type": "integer", "minimum": 0 },
        "memory_pressure": { "type": "string", "minLength": 1 },
        "thermal_state": { "type": "string", "minLength": 1 },
        "low_power_mode": { "type": "boolean" },
        "power_source": { "type": ["string", "null"] },
        "clean_window_verified": { "type": "boolean" },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } }
      },
      "if": { "properties": { "valid": { "const": true } }, "required": ["valid"] },
      "then": {
        "properties": {
          "invalid_reasons": { "maxItems": 0 },
          "errors": { "maxItems": 0 },
          "thermal_state": { "const": "nominal" },
          "low_power_mode": { "const": false },
          "clean_window_verified": { "const": true }
        }
      },
      "else": { "properties": { "invalid_reasons": { "minItems": 1 } } }
    }
  }
}
