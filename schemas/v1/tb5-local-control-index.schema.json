{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anonymuse/QW5/schemas/v1/tb5-local-control-index.schema.json",
  "title": "QW5 Thunderbolt 5 local control index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "artifact_role", "evidence_class", "created_at", "producer", "plan_sha256", "canonical_profile", "entries"],
  "properties": {
    "schema": { "const": "qw5.tb5-local-control-index/v1" },
    "artifact_role": { "enum": ["local_control_index", "schema_fixture"] },
    "evidence_class": { "enum": ["MEASURED", "SIMULATED"] },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer": { "$ref": "#/$defs/producer" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "canonical_profile": { "const": "qw5-json-c14n-v1" },
    "entries": { "type": "array", "minItems": 1, "maxItems": 108, "uniqueItems": true, "items": { "$ref": "#/$defs/entry" } }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_role": { "const": "local_control_index" } }, "required": ["artifact_role"] },
      "then": { "properties": { "evidence_class": { "const": "MEASURED" } } },
      "else": { "properties": { "evidence_class": { "const": "SIMULATED" } } }
    }
  ],
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "relative_path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "producer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "executable_sha256", "qw5_commit", "dirty", "parameters"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 },
        "executable_sha256": { "$ref": "#/$defs/sha256" }, "qw5_commit": { "$ref": "#/$defs/git_commit" },
        "dirty": { "type": "boolean" }, "parameters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entry": {
      "type": "object", "additionalProperties": false,
      "required": ["control_id", "node", "payload_bytes", "relative_path", "sha256"],
      "properties": {
        "control_id": { "enum": ["buffer_copy", "framing", "sha256"] },
        "node": { "enum": ["A", "B", "C"] },
        "payload_bytes": { "enum": [64, 256, 1024, 4096, 16384, 65536, 262144, 1048576, 4194304, 16777216, 67108864, 268435456] },
        "relative_path": { "$ref": "#/$defs/relative_path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
