        {"op": "replace", "path": "/socket_settings/2/flow_id", "value": "b-a"},
        {"op": "copy", "from": "/socket_settings/1", "path": "/socket_settings/-"},
        {"op": "replace", "path": "/socket_settings/3/flow_id", "value": "b-a"},
        {"op": "copy", "from": "/attempts/0/flows/0", "path": "/attempts/0/flows/-"},
        {"op": "replace", "path": "/attempts/0/flows/1/flow_id", "value": "b-a"},
        {"op": "replace", "path": "/attempts/0/synchronization", "value": {"status": "available", "method": "coordinator_receipt_surrogate", "calibration_rounds": 100, "coordinator_receipt_skew_ns": 4000000, "maximum_control_rtt_ns": 100000, "maximum_worker_start_ack_ns": 100000, "timer_resolution_allowance_ns": 50000, "uncertainty_ns": 350000, "start_skew_upper_bound_ns": 4350000, "evidence_sha256": "abababababababababababababababababababababababababababababababab"}},
        {"op": "copy", "from": "/attempts/1/flows/0", "path": "/attempts/1/flows/-"},
        {"op": "replace", "path": "/attempts/1/flows/1/flow_id", "value": "b-a"},
        {"op": "replace", "path": "/attempts/1/synchronization", "value": {"status": "available", "method": "coordinator_receipt_surrogate", "calibration_rounds": 100, "coordinator_receipt_skew_ns": 4000000, "maximum_control_rtt_ns": 100000, "maximum_worker_start_ack_ns": 100000, "timer_resolution_allowance_ns": 50000, "uncertainty_ns": 350000, "start_skew_upper_bound_ns": 4350000, "evidence_sha256": "abababababababababababababababababababababababababababababababab"}},
        {"op": "copy", "from": "/attempts/2/flows/0", "path": "/attempts/2/flows/-"},
        {"op": "replace", "path": "/attempts/2/flows/1/flow_id", "value": "b-a"},
        {"op": "replace", "path": "/attempts/2/synchronization", "value": {"status": "available", "method": "coordinator_receipt_surrogate", "calibration_rounds": 100, "coordinator_receipt_skew_ns": 4000000, "maximum_control_rtt_ns": 100000, "maximum_worker_start_ack_ns": 100000, "timer_resolution_allowance_ns": 50000, "uncertainty_ns": 350000, "start_skew_upper_bound_ns": 4350000, "evidence_sha256": "abababababababababababababababababababababababababababababababab"}},
        {"op": "copy", "from": "/attempts/3/flows/0", "path": "/attempts/3/flows/-"},
        {"op": "replace", "path": "/attempts/3/flows/1/flow_id", "value": "b-a"},
